# ─────────────────────────────────────────────
#  .gitignore  ·  Pronóstico Climatológico CU Tlaquepaque
# ─────────────────────────────────────────────

# Caches y compilados de Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs locales (los regenera el cron)
wwlln_log.txt
*.log

# Archivos comprimidos / respaldos pesados
*.rar
*.zip
*.7z

# NOTA: Los snapshots WWLLN/*.geojson SÍ se suben al repo,
# porque GitHub Pages necesita servirlos (los Actions los regeneran cada 6 h
# y la rotación interna del script mantiene máx. 80 archivos).

# Datos GFS regenerables (estos sí se omiten, pesan mucho y se regeneran)
datos_malla.json

# Editor / SO
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
